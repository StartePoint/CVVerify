{
  "id": "builtin.rotate",
  "displayName": "Rotate",
  "category": "Transform",
  "parameters": [
    {
      "key": "angle",
      "displayName": "Angle",
      "group": "旋转设置",
      "type": "double",
      "default": 0.0,
      "min": -360.0,
      "max": 360.0,
      "step": 0.1,
      "tooltip": "Rotation angle in degrees"
    },
    {
      "key": "scale",
      "displayName": "Scale",
      "group": "旋转设置",
      "type": "double",
      "default": 1.0,
      "min": 0.01,
      "max": 10.0,
      "step": 0.01,
      "tooltip": "Optional uniform scale factor"
    },
    {
      "key": "borderMode",
      "displayName": "Border Mode",
      "group": "输出设置",
      "type": "choice",
      "default": "constant",
      "choices": [
        {
          "value": "constant",
          "label": "Constant"
        },
        {
          "value": "replicate",
          "label": "Replicate"
        },
        {
          "value": "reflect",
          "label": "Reflect"
        },
        {
          "value": "reflect101",
          "label": "Reflect 101"
        }
      ]
    },
    {
      "key": "borderValue",
      "displayName": "Border Value",
      "group": "输出设置",
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 255,
      "step": 1,
      "visibleWhen": "borderMode=constant"
    }
  ]
}
