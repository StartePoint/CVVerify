{
  "id": "builtin.grabcut",
  "displayName": "GrabCut",
  "category": "Segmentation",
  "parameters": [
    {
      "key": "initMode",
      "displayName": "Init Mode",
      "group": "交互设置",
      "type": "choice",
      "default": "rect",
      "tooltip": "Mask mode derives a probable-foreground mask from the selected rectangle",
      "choices": [
        {
          "value": "rect",
          "label": "Rectangle"
        },
        {
          "value": "mask",
          "label": "Mask"
        }
      ]
    },
    {
      "key": "iterCount",
      "displayName": "Iteration Count",
      "group": "分割设置",
      "type": "integer",
      "default": 5,
      "min": 1,
      "max": 20,
      "step": 1
    },
    {
      "key": "outputMode",
      "displayName": "Output Mode",
      "group": "输出设置",
      "type": "choice",
      "default": "foreground_rgba",
      "choices": [
        {
          "value": "foreground_rgba",
          "label": "Foreground RGBA"
        },
        {
          "value": "mask",
          "label": "Mask"
        },
        {
          "value": "overlay",
          "label": "Overlay"
        }
      ]
    },
    {
      "key": "featherRadius",
      "displayName": "Feather Radius",
      "group": "输出设置",
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 50,
      "step": 1,
      "visibleWhen": "outputMode=foreground_rgba"
    }
  ]
}
