      },
      {
        "stepId": "builtin.canny",
        "displayName": "Canny",
        "parameters": {
          "threshold1": 40.0,
          "threshold2": 120.0,
          "apertureSize": 3,
          "useL2Gradient": false
        }
      }
    ]
  },
  "appSettings": {
    "languageCode": "en",
    "maxPreviewFps": 30,
    "previewScale": 1.0,
    "allowFrameSkip": true,
    "previewFrameStep": 1
  }
}
